@page "/"
@rendermode InteractiveServer

<PageTitle>Spot the Freebie 🦋</PageTitle>

<div class="container-fluid header-bar py-3">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-4">
                <button class="btn btn-outline-pink btn-lg rounded-pill">
                    🎲 Losuj darmową grę
                </button>
            </div>

            <div class="col-4 text-center">
                <div class="title-box px-4 py-2 d-inline-block">
                    <span class="title-text">🦋 Spot the Freebie</span>
                </div>
            </div>

            <div class="col-4 text-end">
                <button class="btn btn-outline-pink btn-lg rounded-pill">
                    🏷️ Losuj promocyjną grę
                </button>
            </div>

        </div>
    </div>
</div>

<div class="container my-5">
    <div class="row g-4">

        <div class="col-3">
            <div class="game-card @(selectedCard == 1 ? "selected" : "")" @onclick="() => SelectCard(1)">
                <div class="game-img-area">
                    <span>🎮</span>
                </div>
                <div class="game-info">
                    <p class="placeholder-glow mb-1"><span class="placeholder col-8"></span></p>
                    <span class="price">??? zł</span>
                </div>
            </div>
        </div>

        <div class="col-3">
            <div class="game-card @(selectedCard == 2 ? "selected" : "")" @onclick="() => SelectCard(2)">
                <div class="game-img-area">
                    <span>🎮</span>
                </div>
                <div class="game-info">
                    <p class="placeholder-glow mb-1"><span class="placeholder col-7"></span></p>
                    <span class="price">??? zł</span>
                </div>
            </div>
        </div>

        <div class="col-3">
            <div class="game-card @(selectedCard == 3 ? "selected" : "")" @onclick="() => SelectCard(3)">
                <div class="game-img-area">
                    <span>🎮</span>
                </div>
                <div class="game-info">
                    <p class="placeholder-glow mb-1"><span class="placeholder col-9"></span></p>
                    <span class="price">??? zł</span>
                </div>
            </div>
        </div>

        <div class="col-3">
            <div class="game-card @(selectedCard == 4 ? "selected" : "")" @onclick="() => SelectCard(4)">
                <div class="game-img-area">
                    <span>🎮</span>
                </div>
                <div class="game-info">
                    <p class="placeholder-glow mb-1"><span class="placeholder col-6"></span></p>
                    <span class="price">??? zł</span>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="container text-center my-4">
    <button class="btn btn-sprawdz btn-lg px-5 py-3 rounded-pill"
            disabled="@(selectedCard == null)">
        ✨ SPRAWDŹ ✨
    </button>
</div>

@code {
    private int? selectedCard = null;

    private void SelectCard(int cardIndex)
    {
        selectedCard = cardIndex;
    }
}