@page "/"
@rendermode InteractiveServer

<PageTitle>Spot the Freebie 🦋</PageTitle>

<div class="container text-center py-5">
    <h1 class="display-3 fw-bold mb-4 gradient-text">Spot the Freebie!</h1>
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mx-auto" style="max-width: 600px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
            <button class="btn btn-outline-danger btn-sm ms-3" @onclick="LoadGamesAsync">Spróbuj ponownie</button>
        </div>
    }
</div>

<div class="container-fluid header-bar py-3">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-4">
                <a href="/random-free-game" class="btn btn-outline-pink btn-lg rounded-pill text-decoration-none">
                    🎲 Losuj darmową grę
                </a>
            </div>

            <div class="col-4 text-center">
                <div class="title-box px-4 py-2 d-inline-block">
                    <span class="title-text">🦋 Spot the Freebie</span>
                </div>
            </div>

            <div class="col-4 text-end">
                <a href="/random-sale-game" class="btn btn-outline-pink btn-lg rounded-pill text-decoration-none">
                    🏷️ Losuj promocyjną grę
                </a>
            </div>

        </div>
    </div>
</div>

<div class="container my-5">
    <div class="row g-4">

        @if (gameCards != null)
        {
            for (int i = 0; i < gameCards.Count; i++)
            {
                int index = i;
                var card = gameCards[index];
                <div class="col-3">
                    <div class="game-card @(selectedCard == index ? "selected" : "")" @onclick="() => SelectCard(index)">
                        <div class="game-img-area p-0">
                            <img src="@card.Thumbnail" alt="Game thumbnail" class="w-100 h-100" style="object-fit: cover; opacity: 1;" />
                        </div>
                        <div class="game-info">
                            <p class="mb-1 text-truncate" title="@card.Title">@card.Title</p>
                            @if (!isChecked)
                            {
                                <span class="price">??? zł</span>
                            }
                            else
                            {
                                @if (card.IsFree)
                                {
                                    <span class="price-free">DARMOWA!</span>
                                }
                                else
                                {
                                    <span class="price-strikethrough">@card.NormalPrice$</span>
                                    <span class="price-sale">@card.SalePrice$</span>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            @for (int i = 0; i < 4; i++)
            {
                <div class="col-3">
                    <div class="game-card">
                        <div class="game-img-area">
                            <span class="spinner-border text-pink" role="status" style="color: #c2185b;"></span>
                        </div>
                        <div class="game-info">
                            <p class="placeholder-glow mb-1"><span class="placeholder col-8"></span></p>
                            <span class="price">??? zł</span>
                        </div>
                    </div>
                </div>
            }
        }

    </div>
</div>

@if (isChecked)
{
    var paidGamesTabs = gameCards?.Where(g => !g.IsFree && !string.IsNullOrEmpty(g.GameID)).ToList() ?? new();
    
    <div class="container my-5 fade-in">
        <h3 class="text-center mb-4" style="color: #f48fb1;">Wizualizacja Ofert 📊</h3>
        
        <ul class="nav nav-tabs justify-content-center border-bottom-0 mb-0">
            @foreach (var tabGame in paidGamesTabs)
            {
                <li class="nav-item">
                    <button class="nav-link @(selectedTabGame == tabGame ? "active pink-tab" : "text-light border-0")" 
                            style="cursor: pointer;"
                            @onclick="() => SelectTabGame(tabGame)">
                        @tabGame.Title
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content text-center p-4 rounded-bottom-4 rounded-top-0" style="background-color: #1e1e1e; border: 2px solid #c2185b;">
            @if (isLoadingChart)
            {
                <div class="spinner-border text-pink my-5" role="status"></div>
                <p class="mt-2 text-muted">Ładowanie danych historycznych...</p>
            }
            else if (selectedTabGameDetails != null && selectedTabGame != null)
            {
                <div class="chart-container mx-auto mt-4" style="height: 300px; max-width: 800px; padding-bottom: 0;">
                    <BarChart @ref="barChart" Width="800" Height="300" />
                </div>
                
                @if(selectedTabGameDetails.CheapestPriceEver.Date > 0)
                {
                    <p class="mt-4 text-muted small" style="color: #f48fb1 !important;">
                        Najniższa cena w historii została zarejestrowana: 
                        <strong>@(DateTimeOffset.FromUnixTimeSeconds(selectedTabGameDetails.CheapestPriceEver.Date).ToString("dd.MM.yyyy"))</strong>
                    </p>
                }
            }
        </div>
    </div>
}

<div class="container text-center my-4">
    @if (!isChecked)
    {
        <button class="btn btn-sprawdz btn-lg px-5 py-3 rounded-pill"
                disabled="@(selectedCard == null)"
                @onclick="CheckAnswer">
            ✨ SPRAWDŹ ✨
        </button>
    }
    else
    {
        <button class="btn btn-sprawdz btn-lg px-5 py-3 rounded-pill"
                @onclick="RestartGameAsync">
            🔄 JESZCZE RAZ 🔄
        </button>
    }
</div>