@page "/random-sale-game"
@rendermode InteractiveServer

<PageTitle>Losuj Promocyjną Grę 🏷️</PageTitle>

<div class="container-fluid header-bar py-3">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-4">
                <a href="/" class="btn btn-outline-pink btn-lg rounded-pill text-decoration-none">
                    ⬅️ Powrót do gry
                </a>
            </div>

            <div class="col-4 text-center">
                <div class="title-box px-4 py-2 d-inline-block">
                    <span class="title-text">🏷️ Promocyjna Gra</span>
                </div>
            </div>

            <div class="col-4 text-end">
            </div>

        </div>
    </div>
</div>

<div class="container-fluid px-4 px-xl-5 my-5 d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    @if (game == null)
    {
        <div class="text-center">
            <div class="spinner-border text-pink mb-3" role="status" style="width: 4rem; height: 4rem; color: #c2185b;"></div>
            <h4 style="color: #f48fb1;">Losowanie gry...</h4>
        </div>
    }
    else
    {
        <div class="game-card-wide row g-0 m-0">
            <div class="col-md-5 p-0">
                <div class="game-img-area-wide h-100 w-100 d-flex justify-content-center align-items-center">
                    <img src="@game.Thumb" alt="Game thumbnail" class="w-100 h-100 p-3" style="object-fit: contain;" />
                </div>
            </div>
            
            <div class="col-md-7 p-4 p-md-5 d-flex flex-column text-center text-md-start">
                <h2 class="mb-4 game-title">@game.Title</h2>
                
                <div class="d-flex justify-content-center justify-content-md-start align-items-center mb-4">
                    <span class="price-strikethrough-large">@game.NormalPrice$</span>
                    <span class="price-sale" style="font-size: 2.5rem; margin-left: 15px;">@game.SalePrice$</span>
                </div>
                
                <div class="d-flex justify-content-center justify-content-md-start mb-4">
                    <div class="release-date-box d-inline-block px-4 py-2 rounded-3 text-center">
                        🔥 Oszczędzasz: <strong class="text-white fs-5">-@(game.Savings.Split('.')[0])%</strong>
                    </div>
                </div>

                <div class="deals-section mt-2 mb-4 text-start flex-grow-1">
                    <h5 class="mb-3" style="color: #f48fb1; font-weight: 700;">🛒 Dostępne oferty:</h5>
                    @if (isLoadingDeals)
                    {
                        <div class="d-flex justify-content-center my-4">
                            <div class="spinner-border text-pink" role="status" style="width: 2rem; height: 2rem; color: #c2185b;"></div>
                        </div>
                    }
                    else if (currentDeals.Count == 0)
                    {
                        <p class="text-muted">Brak dodatkowych ofert.</p>
                    }
                    else
                    {
                        <div class="deals-list d-flex flex-column gap-2" style="max-height: 400px; overflow-y: auto; padding-right: 5px;">
                            @foreach (var item in currentDeals)
                            {
                                <a href="https://www.cheapshark.com/redirect?dealID=@item.Deal.DealID" target="_blank" class="deal-item text-decoration-none d-flex justify-content-between align-items-center p-3 rounded-3">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (item.StoreInfo != null)
                                        {
                                            <img src="https://www.cheapshark.com@(item.StoreInfo.Images.Logo)" alt="@item.StoreInfo.StoreName" style="height: 30px; object-fit: contain;" />
                                            <span class="store-name text-light fw-semibold">@item.StoreInfo.StoreName</span>
                                        }
                                        else
                                        {
                                            <span class="store-name text-light fw-semibold">Sklep ID: @item.Deal.StoreID</span>
                                        }
                                    </div>
                                    <div class="deal-price text-end">
                                        <span class="text-white fs-5 fw-bold">@item.Deal.Price$</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </div>

                <button class="btn btn-sprawdz btn-lg px-5 py-3 rounded-pill shadow-lg animate-bounce" @onclick="LoadRandomGameAsync" disabled="@isLoadingDeals">
                    <i class="bi bi-dice-5-fill me-2"></i> LOSUJ PROMOCYJNĄ GRĘ
                </button>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mt-4 mx-auto fade-in" style="max-width: 600px;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                    </div>
                }
            </div>
        </div>
    }
</div>
