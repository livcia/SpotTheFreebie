@page "/random-free-game"
@rendermode InteractiveServer

<PageTitle>Losuj Darmową Grę 🎲</PageTitle>

<div class="container-fluid header-bar py-3">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-4">
                <a href="/" class="btn btn-outline-pink btn-lg rounded-pill">
                    ⬅️ Powrót do gry
                </a>
            </div>

            <div class="col-4 text-center">
                <div class="title-box px-4 py-2 d-inline-block">
                    <span class="title-text">🎲 Darmowa Gra</span>
                </div>
            </div>

            <div class="col-4 text-end">
            </div>

        </div>
    </div>
</div>

<div class="container my-5 d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    @if (game == null)
    {
        <div class="text-center">
            <div class="spinner-border text-pink mb-3" role="status" style="width: 4rem; height: 4rem; color: #c2185b;"></div>
            <h4 style="color: #f48fb1;">Trwa poszukiwanie idealnej darmowej gry...</h4>
        </div>
    }
    else
    {
        <div class="game-card-large">
            <div class="game-img-area p-0">
                <img src="@game.Thumbnail" alt="Game thumbnail" class="w-100 h-100" style="object-fit: cover;" />
            </div>
            
            <div class="game-info-large p-4 text-center">
                <h2 class="mb-3 game-title">@game.Title</h2>
                
                <div class="d-flex justify-content-center gap-3 mb-4">
                    <span class="badge bg-pink">@game.Genre</span>
                    <span class="badge bg-dark-pink">@game.Platform</span>
                </div>
                
                <p class="mb-4 text-light description-text">@game.ShortDescription</p>
                
                <div class="release-date-box mb-4 d-inline-block px-3 py-2 rounded-3">
                    📅 Data wydania: <strong class="text-white">@game.ReleaseDate</strong>
                </div>

                <button class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-lg animate-bounce" @onclick="LoadRandomGameAsync">
                    <i class="bi bi-dice-5-fill me-2"></i> LOSUJ DARMOWĄ GRĘ
                </button>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mt-4 mx-auto fade-in" style="max-width: 600px;">
                        <i class="bi bi-exclamation-triangle me-2"></i> @errorMessage
                    </div>
                }
            </div>
        </div>
    }
</div>
